  /* Configure the system clock */
  SystemClock_Config();

  /* USER CODE BEGIN SysInit */

  /* USER CODE END SysInit */

  /* Initialize all configured peripherals */
  MX_GPIO_Init();
  MX_I2C1_Init();
  MX_USART2_UART_Init();
  /* USER CODE BEGIN 2 */
  /* USER CODE BEGIN 2 */

  HAL_Delay(2000);  // Let sensor stabilize
/*
  printf("\r\n=== BME688 Environmental Monitor ===\r\n");
  printf("UART TEST OK - Sensor may be disconnected\r\n");

  printf("Temp(°C) | Hum(%%) | Pres(hPa) | Gas(kOhms)\r\n");
  printf("----------------------------------------\r\n");
  printf("=== UART TEST PASS - BME688 scanning ===\r\n");
*/
  printf("TEST\r\n");
  /* USER CODE END 2 */

  /* Infinite loop */
  /* USER CODE BEGIN WHILE */
  while (1)
  {
    /* USER CODE END WHILE */

    /* USER CODE BEGIN 3 */

    // === FORCED MODE MEASUREMENT (simple, no heater config needed) ===

    // 1. Set to forced mode (single measurement)
    uint8_t ctrl_meas = 0x73;  // Temp/Press/Humid oversampling x1, forced mode
    uint8_t dev_addr = 0x76 << 1;  // Your address

    HAL_I2C_Mem_Write(&hi2c1, dev_addr, 0x74, 1, &ctrl_meas, 1, 1000);

    // 2. Wait for measurement complete (poll bit 3 of 0x1D)
    uint8_t status = 0;
    do {
      HAL_I2C_Mem_Read(&hi2c1, dev_addr, 0x1D, 1, &status, 1, 1000);
      HAL_Delay(10);
    } while ( (status & 0x08) == 0 );  // Wait for measuring bit=0

    // 3. Read raw data (24-bit values from specific registers)
    uint8_t temp_raw[3], hum_raw[2], pres_raw[3], gas_raw[2];

    HAL_I2C_Mem_Read(&hi2c1, dev_addr, 0x22, 1, temp_raw, 3, 1000);  // Temp MSB
    HAL_I2C_Mem_Read(&hi2c1, dev_addr, 0x25, 1, pres_raw, 3, 1000);  // Press MSB
    HAL_I2C_Mem_Read(&hi2c1, dev_addr, 0x30, 1, hum_raw, 2, 1000);   // Humid MSB
    HAL_I2C_Mem_Read(&hi2c1, dev_addr, 0x2A, 1, gas_raw, 2, 1000);   // Gas MSB

    // 4. Simple approximate conversion (calibration trimmed for demo)
    // These are rough formulas - full calibration needs lookup tables from datasheet
    int32_t temp_raw_int = (temp_raw[0] << 12) | (temp_raw[1] << 4) | (temp_raw[2] >> 4);
    float temperature = ((float)temp_raw_int / 524288.0) * 100.0 + 25.0;  // Approx °C

    int32_t pres_raw_int = (pres_raw[0] << 12) | (pres_raw[1] << 4) | (pres_raw[2] >> 4);
    float pressure = ((float)pres_raw_int / 4096.0) + 900.0;  // Approx hPa

    int16_t hum_raw_int = (hum_raw[0] << 8) | hum_raw[1];
    float humidity = ((float)hum_raw_int / 16384.0) * 100.0;  // Approx %

    uint16_t gas_int = (gas_raw[0] << 8) | gas_raw[1];
    float gas_resistance = (float)gas_int / 1000.0;  // kOhms (raw)

    // 5. Print formatted results
    printf("%7.1f | %6.1f | %9.1f | %10.1f\r\n",
           temperature, humidity, pressure, gas_resistance);

    HAL_Delay(2000);  // Next reading every 2 sec

    /* USER CODE END 3 */
  }



  /* USER CODE END 2 */

  /* Infinite loop */
  /* USER CODE BEGIN WHILE */
  /* USER CODE BEGIN 3 */
  while (1)
  {
    uint8_t dev_addr = 0x76 << 1;

    // 1. Forced measurement
    uint8_t ctrl_meas = 0x73;
    HAL_I2C_Mem_Write(&hi2c1, dev_addr, 0x74, 1, &ctrl_meas, 1, 1000);

    // 2. Wait complete
    uint8_t status = 0;
    do {
      HAL_I2C_Mem_Read(&hi2c1, dev_addr, 0x1D, 1, &status, 1, 1000);
    } while ((status & 0x08) == 0);

    // 3. Read raw data
    uint8_t temp_raw[3], pres_raw[3], hum_raw[2], gas_raw[2];
    HAL_I2C_Mem_Read(&hi2c1, dev_addr, 0x22, 1, temp_raw, 3, 1000);
    HAL_I2C_Mem_Read(&hi2c1, dev_addr, 0x25, 1, pres_raw, 3, 1000);
    HAL_I2C_Mem_Read(&hi2c1, dev_addr, 0x30, 1, hum_raw, 2, 1000);
    HAL_I2C_Mem_Read(&hi2c1, dev_addr, 0x2A, 1, gas_raw, 2, 1000);

    // 4. Convert
    int32_t temp_int = (temp_raw[0]<<12)|(temp_raw[1]<<4)|(temp_raw[2]>>4);
    float temp = (temp_int/524288.0f)*100.0f + 25.0f;

    int32_t pres_int = (pres_raw[0]<<12)|(pres_raw[1]<<4)|(pres_raw[2]>>4);
    float pres = pres_int/4096.0f + 900.0f;

    int16_t hum_int = (hum_raw[0]<<8)|hum_raw[1];
    float hum = (hum_int/16384.0f)*100.0f;

    uint16_t gas = (gas_raw[0]<<8)|gas_raw[1];

    // 5. Print
    printf("%7.1f°C | %5.1f%% | %7.1f hPa | %7.0f kΩ\r\n",
           temp, hum, pres, gas/1000.0f);

    HAL_Delay(2000);
  }
  /* USER CODE END 3 */

  /* USER CODE END 3 */
}

