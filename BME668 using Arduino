//Code for Environmental and Gas sensor (BME 668)


#include <Wire.h>
#include <Adafruit_Sensor.h>
#include <Adafruit_BME680.h>

Adafruit_BME680 bme;  // I2C

void setup() {
  Serial.begin(9600);
  while (!Serial);

  Wire.begin();  // Start I2C

  // Initialize BME688 with address 0x76
  if (!bme.begin(0x76)) {
    Serial.println("Could not find BME688 sensor!");
    while (1);
  }

  // Recommended settings
  bme.setTemperatureOversampling(BME680_OS_8X);
  bme.setHumidityOversampling(BME680_OS_2X);
  bme.setPressureOversampling(BME680_OS_4X);
  bme.setIIRFilterSize(BME680_FILTER_SIZE_3);

  // Gas sensor settings
  bme.setGasHeater(320, 150); // 320°C for 150 ms

  Serial.println("BME688 Sensor Ready!");
  Serial.println("-------------------");
}

void loop() {
  // Perform reading
  if (!bme.performReading()) {
    Serial.println("Failed to read sensor!");
    return;
  }

  // Temperature
  Serial.print("Temperature: ");
  Serial.print(bme.temperature);
  Serial.println(" °C");

  // Humidity
  Serial.print("Humidity: ");
  Serial.print(bme.humidity);
  Serial.println(" %");

  // Pressure
  Serial.print("Pressure: ");
  Serial.print(bme.pressure / 100.0);
  Serial.println(" hPa");

  // Gas resistance
  Serial.print("Gas Resistance: ");
  Serial.print(bme.gas_resistance / 1000.0);
  Serial.println(" KOhms");

  // Simple air quality alert
  if (bme.gas_resistance < 10000) {
    Serial.println("⚠️ Air Quality Poor!");
  } else {
    Serial.println("✅ Air Quality Good");
  }

  Serial.println("-------------------");

  delay(2000);
}
